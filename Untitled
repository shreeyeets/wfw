function Confetti({ show }) {
  const [particles, setParticles] = useState([]);
  
  useEffect(() => {
    if (show) {
      const colors = ['#E8D4E8', '#D4E8E0', '#E8E4D4', '#D4E0E8', '#E8D4D8'];
      const newParticles = Array.from({ length: 35 }).map((_, i) => ({
        id: i,
        x: Math.random() * 100,
        delay: Math.random() * 0.5,
        color: colors[Math.floor(Math.random() * colors.length)]
      }));
      setParticles(newParticles);
    }
  }, [show]);

  if (!show) return null;

  return (
    <div className="fixed inset-0 pointer-events-none overflow-hidden z-50">
      {particles.map(p => (
        <div
          key={p.id}
          className="absolute w-2 h-2 rounded-full animate-confetti"
          style={{
            left: `${p.x}%`,
            backgroundColor: p.color,
            animationDelay: `${p.delay}s`
          }}
        />
      ))}
    </div>
  );
}

function ProgressBar({ current, total }) {
  const percentage = Math.min((current / total) * 100, 100);
  
  return (
    <div className="mb-8">
      <div className="h-1 bg-stone-100 rounded-full overflow-hidden">
        <div 
          className="h-full rounded-full transition-all duration-700 ease-out"
          style={{ 
            width: `${percentage}%`,
            background: 'linear-gradient(90deg, #E8D4E8, #D4E8E0)'
          }}
        />
      </div>
    </div>
  );
}

function QuestionCard({ node, onSelect, onBack, canGoBack }) {
  const [selectedIndex, setSelectedIndex] = useState(null);
  const [isTransitioning, setIsTransitioning] = useState(false);

  const handleSelect = (option, index) => {
    setSelectedIndex(index);
    setIsTransitioning(true);
    setTimeout(() => {
      onSelect(option.next, option.context);
      setSelectedIndex(null);
      setIsTransitioning(false);
    }, 300);
  };

  return (
    <div className={`transition-all duration-300 ${isTransitioning ? 'opacity-0 translate-y-2' : 'opacity-100 translate-y-0'}`}>
      <div className="text-center mb-8">
        <span className="text-3xl mb-4 block">{node.emoji}</span>
        <h2 className="text-xl font-medium text-stone-600 mb-2">
          {node.question}
        </h2>
        <p className="text-stone-400 text-sm">{node.subtext}</p>
      </div>
      
      <div className="space-y-3">
        {node.options.map((option, index) => (
          <button
            key={index}
            onClick={() => handleSelect(option, index)}
            disabled={isTransitioning}
            className={`w-full p-4 text-left rounded-2xl border transition-all duration-200 group
              ${selectedIndex === index 
                ? 'border-stone-200 bg-stone-50' 
                : 'border-stone-100 hover:border-stone-200 hover:bg-stone-50/50'
              }
              ${isTransitioning && selectedIndex !== index ? 'opacity-50' : ''}
            `}
          >
            <div className="flex items-center gap-4">
              <span className="text-xl opacity-60 group-hover:opacity-80 transition-opacity">{option.icon}</span>
              <div className="flex-1">
                <div className="font-medium text-stone-600">{option.label}</div>
              </div>
              <div className="text-stone-200 group-hover:text-stone-400 group-hover:translate-x-0.5 transition-all">
                →
              </div>
            </div>
          </button>
        ))}
      </div>
      
      {canGoBack && (
        <button
          onClick={onBack}
          disabled={isTransitioning}
          className="mt-6 text-stone-300 hover:text-stone-500 text-sm flex items-center gap-2 mx-auto transition-colors"
        >
          <span>←</span> Back
        </button>
      )}
    </div>
  );
}

function ResultCard({ node, onRestart, onAction }) {
  const [showConfetti, setShowConfetti] = useState(false);
  const [showContent, setShowContent] = useState(false);
  
  useEffect(() => {
    setShowConfetti(true);
    setTimeout(() => setShowContent(true), 100);
    const timer = setTimeout(() => setShowConfetti(false), 2500);
    return () => clearTimeout(timer);
  }, []);

  return (
    <div className={`text-center transition-all duration-500 ${showContent ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4'}`}>
      <Confetti show={showConfetti} />
      
      <div 
        className="inline-flex items-center justify-center w-20 h-20 rounded-3xl mb-6"
        style={{ background: 'linear-gradient(135deg, #F5EEF5, #EEF5F2)' }}
      >
        <span className="text-4xl">{node.icon}</span>
      </div>
      
      <div className="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-stone-50 text-stone-500 text-xs font-medium mb-4">
        <span>{node.achievementIcon}</span>
        <span>{node.achievement}</span>
      </div>
      
      <h2 className="text-xl font-medium text-stone-600 mb-3">
        {node.title}
      </h2>
      
      <p className="text-stone-400 mb-8 leading-relaxed text-sm">
        {node.message}
      </p>
      
      <button
        onClick={onAction}
        className="w-full p-4 rounded-2xl text-white font-medium hover:shadow-md hover:translate-y-[-1px] transition-all duration-200 mb-4"
        style={{ background: 'linear-gradient(135deg, #C9B8C9, #B8C9C0)' }}
      >
        {node.action}
      </button>
      
      <button
        onClick={onRestart}
        className="text-stone-300 hover:text-stone-500 text-sm transition-colors"
      >
        Start over
      </button>
    </div>
  );
}

function FeedbackModal({ isOpen, onClose, onSubmit, outcomeData }) {
  const [rating, setRating] = useState(null);
  const [feedback, setFeedback] = useState('');
  const [submitted, setSubmitted] = useState(false);
  const [submitting, setSubmitting] = useState(false);

  if (!isOpen) return null;

  const handleSubmit = async () => {
    setSubmitting(true);
    
    const feedbackData = {
      timestamp: new Date().toISOString(),
      rating: rating,
      feedback: feedback || '(no comment)',
      outcome: outcomeData?.outcomeType || 'unknown',
      supportNeeded: outcomeData?.supportNeeded || 'unknown',
      journeyPath: outcomeData?.journeyPath?.join(' → ') || 'unknown'
    };
    
    try {
      const GOOGLE_SHEETS_URL = 'YOUR_GOOGLE_APPS_SCRIPT_URL_HERE';
      
      if (GOOGLE_SHEETS_URL && GOOGLE_SHEETS_URL !== 'YOUR_GOOGLE_APPS_SCRIPT_URL_HERE') {
        await fetch(GOOGLE_SHEETS_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(feedbackData)
        });
      }
      
      console.log('Feedback submitted:', feedbackData);
    } catch (error) {
      console.error('Error submitting feedback:', error);
    }
    
    onSubmit(feedbackData);
    setSubmitting(false);
    setSubmitted(true);
    
    setTimeout(() => {
      onClose();
      setSubmitted(false);
      setRating(null);
      setFeedback('');
    }, 1500);
  };

  return (
    <div className="fixed inset-0 bg-stone-900/20 backdrop-blur-sm flex items-center justify-center p-4 z-50">
      <div className="bg-white rounded-3xl p-8 max-w-md w-full shadow-xl">
        {submitted ? (
          <div className="text-center py-6">
            <div className="text-4xl mb-3">🙏</div>
            <h3 className="text-lg font-medium text-stone-600">Thank you</h3>
            <p className="text-stone-400 text-sm">Your feedback helps us improve.</p>
          </div>
        ) : (
          <>
            <div className="text-center mb-6">
              <h3 className="text-lg font-medium text-stone-600 mb-1">Quick feedback</h3>
              <p className="text-stone-400 text-sm">Did this help you figure out what you need?</p>
            </div>
            
            <div className="flex gap-1 justify-center mb-6">
              {[
                { emoji: '😕', label: 'No' },
                { emoji: '😐', label: 'Meh' },
                { emoji: '🙂', label: 'A bit' },
                { emoji: '😊', label: 'Yes' },
                { emoji: '🤩', label: 'Yes!' }
              ].map((item, i) => (
                <button
                  key={i}
                  onClick={() => setRating(i + 1)}
                  disabled={submitting}
                  className={`flex flex-col items-center p-3 rounded-xl transition-all ${
                    rating === i + 1 
                      ? 'bg-stone-100 scale-105' 
                      : 'hover:bg-stone-50'
                  }`}
                >
                  <span className="text-2xl">{item.emoji}</span>
                  <span className="text-[10px] text-stone-400 mt-1">{item.label}</span>
                </button>
              ))}
            </div>
            
            <textarea
              value={feedback}
              onChange={(e) => setFeedback(e.target.value)}
              placeholder="Any other thoughts? (optional)"
              disabled={submitting}
              className="w-full p-4 border border-stone-100 rounded-2xl resize-none h-24 mb-4 focus:outline-none focus:border-stone-200 transition-colors text-sm text-stone-600 placeholder-stone-300"
            />
            
            <div className="flex gap-3">
              <button
                onClick={onClose}
                disabled={submitting}
                className="flex-1 p-3 rounded-2xl border border-stone-100 text-stone-400 hover:bg-stone-50 font-medium transition-colors text-sm"
              >
                Skip
              </button>
              <button
                onClick={handleSubmit}
                disabled={!rating || submitting}
                className={`flex-1 p-3 rounded-2xl font-medium transition-all text-sm ${
                  rating && !submitting
                    ? 'text-white hover:shadow-md'
                    : 'bg-stone-100 text-stone-300 cursor-not-allowed'
                }`}
                style={rating && !submitting ? { background: 'linear-gradient(135deg, #C9B8C9, #B8C9C0)' } : {}}
              >
                {submitting ? 'Sending...' : 'Submit'}
              </button>
            </div>
          </>
